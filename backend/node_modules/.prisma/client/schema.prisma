  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportType    String   @map("report_type") @db.VarChar(100)
  reportScope   String   @map("report_scope") @db.VarChar(100)
  generatedById String   @map("generated_by") @db.Uuid
  generatedAt   DateTime @default(now()) @map("generated_at") @db.Timestamptz(6)
  fileUrl       String?  @map("file_url") @db.Text
  exportFormat  String   @map("export_format") @db.VarChar(20) // PDF, EXCEL, CSV

  generatedBy User @relation(fields: [generatedById], references: [id], onUpdate: Cascade, onDelete: Restrict)

  @@index([reportType, generatedAt])
  @@map("operational_reports")
}

model WarehouseExport {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  exportType   String       @map("export_type") @db.VarChar(100)
  exportScope  String       @map("export_scope") @db.VarChar(100)
  exportStatus ExportStatus @default(PENDING) @map("export_status")
  generatedAt  DateTime     @default(now()) @map("generated_at") @db.Timestamptz(6)
  fileUrl      String?      @map("file_url") @db.Text

  @@index([exportStatus])
  @@map("warehouse_exports")
}

model SystemHealthLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceName String   @map("service_name") @db.VarChar(100)
  eventType   String   @map("event_type") @db.VarChar(100)
  severity    String   @db.VarChar(50) // INFO, WARN, ERROR, CRITICAL
  message     String   @db.Text
  metadata    Json?    @db.JsonB
  occurredAt  DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  @@index([serviceName, occurredAt])
  @@map("system_health_logs")
}
