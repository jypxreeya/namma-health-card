generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------------------
// Enums
// ------------------------------------------------------

enum RecordStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ConsentStatus {
  GRANTED
  REVOKED
}

enum DocumentType {
  AADHAAR
  PAN
  VOTER_ID
  PASSPORT
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CardStatus {
  ISSUED
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
}

enum RelationshipType {
  SPOUSE
  CHILD
  PARENT
  SIBLING
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  NOT_INTERESTED
  CONVERTED
}

enum VisitType {
  IN_PERSON
  CALL
  FOLLOW_UP
}

enum VisitStatus {
  PLANNED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AssignmentStatus {
  ACTIVE
  INACTIVE
}

// ------------------------------------------------------
// User Management
// ------------------------------------------------------

model User {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String? @unique @map("employee_id") @db.VarChar(50)
  firstName  String  @map("first_name") @db.VarChar(100)
  lastName   String? @map("last_name") @db.VarChar(100)
  email      String? @unique @db.VarChar(255)
  mobile     String  @unique @db.VarChar(20)

  // Security & Authentication
  passwordHash        String    @map("password_hash") @db.VarChar(255)
  mfaEnabled          Boolean   @default(false) @map("mfa_enabled")
  mfaSecret           String?   @map("mfa_secret") @db.VarChar(255)
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until") @db.Timestamptz(6)

  // Relations
  roleId String @map("role_id") @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  // Metadata & Auditing
  status    RecordStatus @default(ACTIVE)
  version   Int          @default(1)
  isDeleted Boolean      @default(false) @map("is_deleted")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  sessions  Session[]
  auditLogs AuditLog[]
  Patient   Patient[]

  assignedLeads               Lead[]                       @relation("AssignedLeads")
  executiveVisits             FieldVisit[]                 @relation("ExecutiveVisits")
  leadConversions             LeadConversionLog[]          @relation("LeadConversions")
  executiveTargets            ExecutiveTarget[]            @relation("ExecutiveTargets")
  areaAssignments             AreaAssignment[]             @relation("AreaAssignments")
  receptionStaff              ReceptionUser[]              @relation("ReceptionStaff")
  commissions                 ExecutiveCommission[]        @relation("ExecutiveCommissions")
  assignedTickets             SupportTicket[]              @relation("AssignedTickets")
  executivePerformanceMetrics ExecutivePerformanceMetric[]
  operationalReports          OperationalReport[]

  @@index([email, status, isDeleted])
  @@index([roleId])
  @@map("users")
}

model Session {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  token             String  @unique @db.VarChar(512)
  ipAddress         String? @map("ip_address") @db.VarChar(45)
  userAgent         String? @map("user_agent") @db.Text
  deviceFingerprint String? @map("device_fingerprint") @db.VarChar(255)

  expiresAt      DateTime @map("expires_at") @db.Timestamptz(6)
  lastActivityAt DateTime @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  refreshToken   String?  @unique @map("refresh_token") @db.VarChar(512)
  isRevoked      Boolean  @default(false) @map("is_revoked")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([token])
  @@index([refreshToken])
  @@index([userId, isRevoked])
  @@map("sessions")
}

// ------------------------------------------------------
// Role-Based Access Control (RBAC)
// ------------------------------------------------------

model Role {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String  @unique @db.VarChar(100)
  code        String  @unique @db.VarChar(50)
  description String? @db.Text

  status    RecordStatus @default(ACTIVE)
  version   Int          @default(1)
  isDeleted Boolean      @default(false) @map("is_deleted")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  users       User[]
  permissions RolePermission[]
  menuAccess  RoleMenuAccess[]

  @@index([status, isDeleted])
  @@map("roles")
}

model Permission {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  module      String  @db.VarChar(100) // e.g., 'PATIENT', 'BILLING'
  action      String  @db.VarChar(100) // e.g., 'CREATE', 'READ', 'UPDATE', 'DELETE'
  description String? @db.Text

  status    RecordStatus @default(ACTIVE)
  version   Int          @default(1)
  isDeleted Boolean      @default(false) @map("is_deleted")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ------------------------------------------------------
// Dynamic Sidebar / Menus
// ------------------------------------------------------

model Menu {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label     String  @db.VarChar(100)
  icon      String? @db.VarChar(100)
  path      String  @db.VarChar(255)
  parentId  String? @map("parent_id") @db.Uuid
  sortOrder Int     @default(0) @map("sort_order")

  parent   Menu?  @relation("MenuHierarchy", fields: [parentId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  children Menu[] @relation("MenuHierarchy")

  status    RecordStatus @default(ACTIVE)
  version   Int          @default(1)
  isDeleted Boolean      @default(false) @map("is_deleted")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  roleAccess RoleMenuAccess[]

  @@index([parentId])
  @@index([status, isDeleted])
  @@map("menus")
}

model RoleMenuAccess {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId String @map("role_id") @db.Uuid
  menuId String @map("menu_id") @db.Uuid

  role Role @relation(fields: [roleId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  menu Menu @relation(fields: [menuId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([roleId, menuId])
  @@index([roleId])
  @@index([menuId])
  @@map("role_menu_access")
}

// ------------------------------------------------------
// Audit Logging
// ------------------------------------------------------

model AuditLog {
  id     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String? @map("user_id") @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: SetNull)

  action     String  @db.VarChar(100) // e.g., 'LOGIN', 'CREATE_USER'
  entityType String? @map("entity_type") @db.VarChar(100) // e.g., 'User', 'Role'
  entityId   String? @map("entity_id") @db.Uuid

  oldValues Json? @map("old_values") @db.JsonB
  newValues Json? @map("new_values") @db.JsonB

  ipAddress String? @map("ip_address") @db.VarChar(45)
  userAgent String? @map("user_agent") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityType, entityId])
  @@index([userId, action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ------------------------------------------------------
// Patient Management
// ------------------------------------------------------

model Patient {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientCode String    @unique @map("patient_code") @db.VarChar(50)
  fullName    String    @map("full_name") @db.VarChar(150)
  mobile      String    @unique @db.VarChar(20)
  email       String?   @db.VarChar(255)
  dob         DateTime? @db.Date
  gender      Gender?

  primaryAddressId   String? @map("primary_address_id") @db.Uuid
  fieldExecutiveId   String? @map("field_executive_id") @db.Uuid
  activeMembershipId String? @map("active_membership_id") @db.Uuid

  kycStatus          KycStatus     @default(PENDING) @map("kyc_status")
  consentStatus      ConsentStatus @default(REVOKED) @map("consent_status")
  registrationSource String?       @map("registration_source") @db.VarChar(50)

  fieldExecutive User? @relation(fields: [fieldExecutiveId], references: [id], onDelete: SetNull)

  addresses      PatientAddress[]
  familyMembers  FamilyMember[]
  documents      PatientDocument[]
  consentRecords ConsentRecord[]
  memberships    Membership[]
  healthCards    HealthCard[]

  fieldVisits     FieldVisit[]
  leadConversions LeadConversionLog[]

  status    RecordStatus @default(ACTIVE)
  version   Int          @default(1)
  isDeleted Boolean      @default(false) @map("is_deleted")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  patientVisits      PatientVisit[]              @relation("PatientVisits")
  benefitUsages      CardBenefitUsage[]          @relation("PatientBenefitUsage")
  commissions        ExecutiveCommission[]       @relation("PatientCommissions")
  membershipPayments OptionalMembershipPayment[] @relation("MembershipPayments")
  cardRenewals       CardRenewal[]               @relation("PatientRenewals")
  customerSessions   CustomerSession[]
  notifications      Notification[]
  whatsappLogs       WhatsAppLog[]
  smsLogs            SmsLog[]
  emailLogs          EmailLog[]
  supportTickets     SupportTicket[]
  feedbacks          Feedback[]
  activityLogs       CustomerActivityLog[]

  @@index([mobile])
  @@index([patientCode])
  @@index([fieldExecutiveId])
  @@map("patients")
}

model PatientAddress {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String  @map("patient_id") @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  addressLine1 String   @map("address_line_1") @db.VarChar(255)
  addressLine2 String?  @map("address_line_2") @db.VarChar(255)
  city         String   @db.VarChar(100)
  state        String   @db.VarChar(100)
  postalCode   String   @map("postal_code") @db.VarChar(20)
  country      String   @default("India") @db.VarChar(100)
  geoLat       Decimal? @map("geo_lat") @db.Decimal(10, 8)
  geoLong      Decimal? @map("geo_long") @db.Decimal(11, 8)

  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([patientId])
  @@map("patient_addresses")
}

model FamilyMember {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String  @map("patient_id") @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  fullName         String           @map("full_name") @db.VarChar(150)
  relationshipType RelationshipType @map("relationship_type")
  dob              DateTime?        @db.Date
  gender           Gender?
  mobile           String?          @db.VarChar(20)

  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  beneficiaryVisits PatientVisit[] @relation("BeneficiaryVisits")

  @@index([patientId])
  @@map("family_members")
}

model PatientDocument {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String  @map("patient_id") @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  documentType       DocumentType       @map("document_type")
  documentUrl        String             @map("document_url") @db.VarChar(512)
  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")

  uploadedAt DateTime @default(now()) @map("uploaded_at") @db.Timestamptz(6)

  @@index([patientId])
  @@map("patient_documents")
}

model ConsentRecord {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String  @map("patient_id") @db.Uuid
  patient   Patient @relation(fields: [patientId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  consentType    String  @map("consent_type") @db.VarChar(100) // e.g., 'TERMS_AND_CONDITIONS'
  consentVersion String  @map("consent_version") @db.VarChar(50)
  ipAddress      String? @map("ip_address") @db.VarChar(45)

  status         ConsentStatus @default(GRANTED)
  consentGivenAt DateTime      @default(now()) @map("consent_given_at") @db.Timestamptz(6)

  @@index([patientId])
  @@map("consent_records")
}

// ------------------------------------------------------
// Membership & Cards
// ------------------------------------------------------

model MembershipPlan {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planCode     String  @unique @map("plan_code") @db.VarChar(50)
  planName     String  @map("plan_name") @db.VarChar(150)
  durationDays Int     @map("duration_days")
  pricing      Decimal @db.Decimal(10, 2)
  familyLimit  Int     @default(0) @map("family_limit")
  benefits     Json?   @db.JsonB

  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships        Membership[]
  membershipPayments OptionalMembershipPayment[] @relation("PlanPayments")

  @@index([planCode])
  @@map("membership_plans")
}

model Membership {
  id               String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId        String @map("patient_id") @db.Uuid
  membershipPlanId String @map("membership_plan_id") @db.Uuid

  patient        Patient        @relation(fields: [patientId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  membershipPlan MembershipPlan @relation(fields: [membershipPlanId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  enrolledAt    DateTime @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  validFrom     DateTime @map("valid_from") @db.Timestamptz(6)
  validTo       DateTime @map("valid_to") @db.Timestamptz(6)
  renewalStatus String   @default("ACTIVE") @map("renewal_status") @db.VarChar(50) // e.g. EXPIRED, RENEWED

  status RecordStatus @default(ACTIVE)

  healthCards HealthCard[]
  renewals    Renewal[]

  @@index([patientId])
  @@index([membershipPlanId])
  @@map("memberships")
}

model HealthCard {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId    String @map("patient_id") @db.Uuid
  membershipId String @map("membership_id") @db.Uuid

  patient    Patient    @relation(fields: [patientId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  cardNumber String  @unique @map("card_number") @db.VarChar(100)
  qrCodeUrl  String? @map("qr_code_url") @db.VarChar(512)
  pdfUrl     String? @map("pdf_url") @db.VarChar(512)

  issueDate  DateTime   @default(now()) @map("issue_date") @db.Timestamptz(6)
  expiryDate DateTime   @map("expiry_date") @db.Timestamptz(6)
  cardStatus CardStatus @default(ISSUED) @map("card_status")

  statusHistory CardStatusHistory[]

  @@index([cardNumber])
  @@index([cardStatus])
  @@index([patientId])
  @@index([membershipId])
  @@map("health_cards")
}

model CardStatusHistory {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cardId     String     @map("card_id") @db.Uuid
  healthCard HealthCard @relation(fields: [cardId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  oldStatus CardStatus @map("old_status")
  newStatus CardStatus @map("new_status")
  changedAt DateTime   @default(now()) @map("changed_at") @db.Timestamptz(6)

  @@index([cardId])
  @@map("card_status_history")
}

model Renewal {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  membershipId String     @map("membership_id") @db.Uuid
  membership   Membership @relation(fields: [membershipId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  previousExpiry   DateTime @map("previous_expiry") @db.Timestamptz(6)
  newExpiry        DateTime @map("new_expiry") @db.Timestamptz(6)
  renewalDate      DateTime @default(now()) @map("renewal_date") @db.Timestamptz(6)
  paymentReference String?  @map("payment_reference") @db.VarChar(255)

  @@index([membershipId])
  @@map("renewals")
}

// ------------------------------------------------------
// Field Operations & Lead Management
// ------------------------------------------------------

model Lead {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadCode        String  @unique @map("lead_code") @db.VarChar(50)
  fullName        String  @map("full_name") @db.VarChar(150)
  mobile          String  @db.VarChar(20)
  alternateMobile String? @map("alternate_mobile") @db.VarChar(20)
  address         String? @db.Text
  area            String? @db.VarChar(100)
  source          String? @db.VarChar(50)

  leadStatus          LeadStatus @default(NEW) @map("lead_status")
  assignedExecutiveId String?    @map("assigned_executive_id") @db.Uuid
  assignedExecutive   User?      @relation("AssignedLeads", fields: [assignedExecutiveId], references: [id], onDelete: SetNull)

  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  fieldVisits    FieldVisit[]
  conversionLogs LeadConversionLog[]
  commissions    ExecutiveCommission[] @relation("LeadCommissions")

  @@index([mobile])
  @@index([leadCode])
  @@index([assignedExecutiveId])
  @@map("leads")
}

model FieldVisit {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  executiveId String  @map("executive_id") @db.Uuid
  leadId      String  @map("lead_id") @db.Uuid
  patientId   String? @map("patient_id") @db.Uuid

  executive User     @relation("ExecutiveVisits", fields: [executiveId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  lead      Lead     @relation(fields: [leadId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  patient   Patient? @relation(fields: [patientId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  visitDate   DateTime    @map("visit_date") @db.Timestamptz(6)
  visitType   VisitType   @default(IN_PERSON) @map("visit_type")
  visitStatus VisitStatus @default(PLANNED) @map("visit_status")

  geoLat  Decimal? @map("geo_lat") @db.Decimal(10, 8)
  geoLong Decimal? @map("geo_long") @db.Decimal(11, 8)
  notes   String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([executiveId, visitDate])
  @@map("field_visits")
}

model LeadConversionLog {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId        String @map("lead_id") @db.Uuid
  patientId     String @map("patient_id") @db.Uuid
  convertedById String @map("converted_by") @db.Uuid

  lead        Lead    @relation(fields: [leadId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  patient     Patient @relation(fields: [patientId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  convertedBy User    @relation("LeadConversions", fields: [convertedById], references: [id], onUpdate: Cascade, onDelete: Restrict)

  conversionDate  DateTime @default(now()) @map("conversion_date") @db.Timestamptz(6)
  conversionNotes String?  @map("conversion_notes") @db.Text

  @@index([leadId])
  @@map("lead_conversion_logs")
}

model ExecutiveTarget {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  executiveId String @map("executive_id") @db.Uuid
  executive   User   @relation("ExecutiveTargets", fields: [executiveId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  targetPeriod          String  @map("target_period") @db.VarChar(50) // e.g., '2026-Q2', '2026-05'
  targetRegistrations   Int     @default(0) @map("target_registrations")
  achievedRegistrations Int     @default(0) @map("achieved_registrations")
  targetRevenue         Decimal @default(0.0) @map("target_revenue") @db.Decimal(12, 2)
  achievedRevenue       Decimal @default(0.0) @map("achieved_revenue") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([executiveId])
  @@map("executive_targets")
}

model AreaAssignment {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  executiveId String @map("executive_id") @db.Uuid
  executive   User   @relation("AreaAssignments", fields: [executiveId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  areaName   String @map("area_name") @db.VarChar(100)
  city       String @db.VarChar(100)
  state      String @db.VarChar(100)
  postalCode String @map("postal_code") @db.VarChar(20)

  assignmentStatus AssignmentStatus @default(ACTIVE) @map("assignment_status")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([executiveId])
  @@map("area_assignments")
}

// ======================================================
// PHASE 5 — Partner Hospital Operations (NHC Scoped)
// ======================================================

enum PartnerHospitalStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum HospitalVisitStatus {
  CHECKED_IN
  COMPLETED
  CANCELLED
}

enum ServiceCategory {
  OPD
  DIAGNOSTIC
  SPECIALIST
  PHARMACY
  EMERGENCY
}

enum VisitDocumentType {
  PRESCRIPTION
  LAB_REPORT
