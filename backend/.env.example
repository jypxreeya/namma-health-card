# Database Configuration
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="health_card_dev"
POSTGRES_PORT="5433"
POSTGRES_HOST="127.0.0.1"

# Prisma Database URL (Transaction Mode / Pooled)
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# Direct Connection URL (Session Mode / Migrations)
# Use this for Supabase (Port 5432) or other pooled connections
DIRECT_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# Seed Environment Configuration (dev or prod)
# If 'prod', seed scripts will not insert test users or default passwords.
SEED_ENV="dev"

# Authentication (for next steps)
JWT_SECRET="super_secret_jwt_key_please_change_in_production"
JWT_EXPIRES_IN="1h"
